@model IReadOnlyList<PetShop.Models.ProductDto_temp>

@{
    var q = (ViewData["q"] as string) ?? "";
    string FormatVnd(decimal value) => string.Format(new System.Globalization.CultureInfo("vi-VN"), "{0:c0}", value);
    var cart = Context.Session.GetJson<List<CartItem>>("cart") ?? new List<CartItem>();
    var cartQty = cart.Sum(x => x.Quantity);
}

<!doctype html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>PetShop - Chọn sản phẩm</title>
    <style>
        :root { color-scheme: light dark; }
        body { font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif; margin: 0; background: #0f1116; color: rgba(255,255,255,.9); }
        a { color: inherit; text-decoration: none; }
        .wrap { width: min(1100px, 92vw); margin: 0 auto; padding: 28px 0 40px; }
        .top { display:flex; align-items:center; justify-content: space-between; gap: 12px; }
        .cartLink { opacity:.9; padding: 8px 10px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.14); background: rgba(255,255,255,0.06); }
        .cartLink:hover { border-color: rgba(100,108,255,0.55); }
        .kicker { opacity:.72; letter-spacing:.16em; text-transform: uppercase; font-size: 12px; }
        h1 { margin: 6px 0 6px; font-size: clamp(28px, 4vw, 44px); line-height: 1.12; }
        .sub { opacity:.78; }
        .bar { display:flex; gap: 10px; align-items: end; justify-content: space-between; margin: 14px 0 10px; flex-wrap: wrap; }
        .field { display:grid; gap:6px; font-size: 12px; }
        .field span { opacity:.75; }
        input { height: 38px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.14); background: rgba(255,255,255,0.06); color: inherit; padding: 0 12px; min-width: min(520px, 70vw); outline: none; }
        input:focus { border-color: rgba(100,108,255,.9); box-shadow: 0 0 0 3px rgba(100,108,255,.18); }
        button { height: 38px; padding: 0 14px; border-radius: 10px; border: 1px solid rgba(100,108,255,0.55); background: rgba(100,108,255,0.25); color: inherit; cursor: pointer; }
        .grid { margin-top: 14px; display:grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 14px; }
        .card { border: 1px solid rgba(255,255,255,0.14); background: rgba(255,255,255,0.04); border-radius: 16px; overflow:hidden; box-shadow: 0 18px 40px rgba(0,0,0,.18); display:block; }
        .card:hover { border-color: rgba(100,108,255,0.55); }
        .imgWrap { height: 160px; background: rgba(255,255,255,0.06); position: relative; }
        .imgWrap img { width:100%; height:100%; object-fit:cover; display:block; }
        .badge { position:absolute; left:10px; top:10px; font-size: 12px; padding: 6px 10px; border-radius: 999px; background: rgba(0,0,0,.55); border: 1px solid rgba(255,255,255,.22); }
        .badgeOut { background: rgba(140,20,20,.65); }
        .body { padding: 12px 12px 14px; display:grid; gap: 8px; }
        .name { font-weight: 800; line-height: 1.2; }
        .meta { display:flex; gap: 10px; opacity: .78; font-size: 13px; flex-wrap: wrap; }
        .desc { opacity: .82; font-size: 13px; line-height: 1.45; min-height: 2.9em; }
        .foot { display:flex; align-items:center; justify-content: space-between; gap: 10px; margin-top: 2px; }
        .price { font-weight: 900; letter-spacing: .2px; }
        .cta { opacity: .9; padding: 8px 10px; border-radius: 12px; border: 1px solid rgba(100,108,255,0.55); background: rgba(100,108,255,0.18); }
        .empty { padding: 16px 12px; opacity: .75; border: 1px dashed rgba(255,255,255,.22); border-radius: 14px; }
        @@media (max-width: 980px) { .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } input { min-width: min(420px, 80vw); } }
        @@media (max-width: 560px) { .grid { grid-template-columns: 1fr; } input { min-width: 0; width: 100%; } }
    </style>
</head>
<body>
    <div class="wrap">
        <div class="top">
            <div class="kicker">PetShop</div>
            <a class="cartLink" href="/cart">Giỏ hàng (@cartQty)</a>
        </div>
        <h1>Chọn sản phẩm</h1>
        <div class="sub">Tổng: <b>@Model.Count</b> sản phẩm</div>

        <form method="get" class="bar">
            <label class="field">
                <span>Tìm</span>
                <input name="q" value="@q" placeholder="Tên, mô tả, loại, nhà cung cấp..." />
            </label>
            <button type="submit">Tìm</button>
        </form>

        @if (Model.Count == 0)
        {
            <div class="empty">Không có sản phẩm nào.</div>
        }
        else
        {
            <div class="grid">
                @foreach (var p in Model)
                {
                    var outOfStock = p.StockQuantity <= 0;
                    <a class="card" href="/products/@p.ProductId" title="Xem chi tiết">
                        <div class="imgWrap">
                            @if (!string.IsNullOrWhiteSpace(p.ImageUrl))
                            {
                                <img src="@p.ImageUrl" alt="@p.Name" loading="lazy" />
                            }
                            <div class="badge @(outOfStock ? "badgeOut" : "")">@(outOfStock ? "Hết hàng" : $"Còn {p.StockQuantity}")</div>
                        </div>
                        <div class="body">
                            <div class="name">@p.Name</div>
                            <div class="meta">
                                <div>@(p.CategoryName ?? "—")</div>
                                <div>•</div>
                                <div>@(p.SupplierName ?? "—")</div>
                            </div>
                            <div class="desc">@(string.IsNullOrWhiteSpace(p.Description) ? "Không có mô tả." : p.Description)</div>
                            <div class="foot">
                                <div class="price">@FormatVnd(p.Price)</div>
                                <span class="cta">Xem chi tiết →</span>
                            </div>
                        </div>
                    </a>
                }
            </div>
        }
    </div>
</body>
</html>
