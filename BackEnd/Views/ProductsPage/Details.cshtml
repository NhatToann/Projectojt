@model PetShop.Models.ProductDto_temp

@{
    string FormatVnd(decimal value) => string.Format(new System.Globalization.CultureInfo("vi-VN"), "{0:c0}", value);
    var outOfStock = Model.StockQuantity <= 0;
    var cart = Context.Session.GetJson<List<CartItem>>("cart") ?? new List<CartItem>();
    var inCartQty = cart.FirstOrDefault(x => x.ProductId == Model.ProductId)?.Quantity ?? 0;
    var cartQty = cart.Sum(x => x.Quantity);
}

<!doctype html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@Model.Name - PetShop</title>
    <style>
        :root { color-scheme: light dark; }
        body { font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif; margin: 0; background: #0f1116; color: rgba(255,255,255,.9); }
        a { color: inherit; text-decoration: none; }
        .wrap { width: min(1100px, 92vw); margin: 0 auto; padding: 28px 0 40px; }
        .top { display:flex; align-items:center; justify-content: space-between; gap: 12px; margin-bottom: 14px; }
        .back { display:inline-flex; align-items:center; gap: 8px; opacity:.85; }
        .cartLink { opacity:.9; padding: 8px 10px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.14); background: rgba(255,255,255,0.06); }
        .cartLink:hover { border-color: rgba(100,108,255,0.55); }
        .card { border: 1px solid rgba(255,255,255,0.14); background: rgba(255,255,255,0.04); border-radius: 18px; overflow:hidden; box-shadow: 0 18px 40px rgba(0,0,0,.18); }
        .grid { display:grid; grid-template-columns: 1fr 1fr; gap: 0; }
        .imgWrap { min-height: 340px; background: rgba(255,255,255,0.06); position: relative; }
        .imgWrap img { width:100%; height:100%; object-fit:cover; display:block; }
        .badge { position:absolute; left:12px; top:12px; font-size: 12px; padding: 6px 10px; border-radius: 999px; background: rgba(0,0,0,.55); border: 1px solid rgba(255,255,255,.22); }
        .badgeOut { background: rgba(140,20,20,.65); }
        .body { padding: 16px 16px 18px; display:grid; gap: 10px; }
        h1 { margin: 0; font-size: clamp(24px, 3vw, 34px); line-height: 1.15; }
        .meta { display:flex; gap: 10px; opacity: .78; font-size: 13px; flex-wrap: wrap; }
        .price { font-weight: 900; font-size: 20px; letter-spacing: .2px; }
        .desc { opacity: .9; line-height: 1.6; white-space: pre-wrap; }
        .hint { opacity: .78; font-size: 13px; }
        .actions { display:flex; align-items:center; justify-content: space-between; gap: 10px; padding-top: 8px; border-top: 1px solid rgba(255,255,255,0.10); }
        .qty { display:inline-flex; align-items:center; gap: 8px; flex-wrap: wrap; justify-content: flex-end; }
        .qty input { width: 92px; height: 38px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.14); background: rgba(255,255,255,0.06); color: inherit; padding: 0 10px; }
        .ctaBtn { height: 38px; padding: 0 14px; border-radius: 12px; border: 1px solid rgba(100,108,255,0.55); background: rgba(100,108,255,0.25); color: inherit; cursor: pointer; }
        .ctaBtn:disabled { opacity: .5; cursor: not-allowed; }
        @@media (max-width: 860px) { .grid { grid-template-columns: 1fr; } .imgWrap { min-height: 240px; } }
    </style>
</head>
<body>
    <div class="wrap">
        <div class="top">
            <a class="back" href="/products">← Quay lại</a>
            <a class="cartLink" href="/cart">Giỏ hàng (@cartQty)</a>
        </div>

        <section class="card">
            <div class="grid">
                <div class="imgWrap">
                    @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" alt="@Model.Name" />
                    }
                    <div class="badge @(outOfStock ? "badgeOut" : "")">@(outOfStock ? "Hết hàng" : $"Còn {Model.StockQuantity}")</div>
                </div>

                <div class="body">
                    <h1>@Model.Name</h1>
                    <div class="meta">
                        <div>Loại: <b>@(Model.CategoryName ?? "—")</b></div>
                        <div>•</div>
                        <div>Nhà cung cấp: <b>@(Model.SupplierName ?? "—")</b></div>
                    </div>
                    <div class="price">@FormatVnd(Model.Price)</div>
                    <div class="desc">@(string.IsNullOrWhiteSpace(Model.Description) ? "Không có mô tả." : Model.Description)</div>
                    <div class="hint">Trong giỏ hàng: <b>@inCartQty</b> sản phẩm</div>

                    <div class="actions">
                        <div style="opacity:.8">Tồn kho: <b>@Model.StockQuantity</b></div>
                        <form method="post" action="/cart/add/@Model.ProductId" style="margin:0">
                            <input type="hidden" name="goCart" value="true" />
                            <div class="qty">
                                <label style="opacity:.8" for="qty">Số lượng</label>
                                <input id="qty" name="qty" type="number" min="1" max="@Model.StockQuantity" value="1" @(outOfStock ? "disabled" : null) />
                                <button class="ctaBtn" type="submit" disabled="@(outOfStock ? "disabled" : null)">Add to cart</button>
                                <a href="/cart" style="opacity:.85">Xem giỏ</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </section>
    </div>
</body>
</html>
